DATABASE_URL="postgresql://postgres:YOUR_POSTGRES_PASSWORD@127.0.0.1:5432/sentify?schema=public"
JWT_SECRET="replace-with-a-long-random-secret"
JWT_ISSUER="sentify-api"
JWT_AUDIENCE="sentify-web"
LOG_FORMAT="auto"
CORS_ORIGIN="http://localhost:5173"
BODY_LIMIT="100kb"
AUTH_COOKIE_NAME="sentify_access_token"
AUTH_COOKIE_SAME_SITE="lax"
AUTH_COOKIE_SECURE="false"
# Use "en" for the most stable Google Maps labels during browser automation.
REVIEW_BROWSER_HEADLESS="true"
REVIEW_BROWSER_LANGUAGE_CODE="en"
REVIEW_BROWSER_TIMEOUT_MS=45000
REVIEW_BROWSER_PROFILE_BOOTSTRAP_TIMEOUT_MS=12000
REVIEW_BROWSER_STATE_CACHE_MS=300000
REVIEW_BROWSER_IDLE_CLOSE_MS=60000
REVIEW_BROWSER_SCROLL_STEPS=24
REVIEW_BROWSER_SCROLL_DELAY_MS=450
# 0 means "crawl until feed exhaustion", bounded by REVIEW_BROWSER_HARD_MAX_REVIEWS.
REVIEW_BROWSER_MAX_REVIEWS=0
REVIEW_BROWSER_HARD_MAX_REVIEWS=320
REVIEW_BROWSER_STALL_LIMIT=6
REVIEW_BROWSER_HEAD_SYNC_TARGET=24
REVIEW_BROWSER_RECENT_SYNC_TARGET=60
REVIEW_BROWSER_DUPLICATE_STREAK_LIMIT=12
REVIEW_BROWSER_MIN_REVIEWS_BEFORE_EARLY_STOP=12
REVIEW_BROWSER_CHANNEL=""
# Example on Windows: C:\Program Files\Google\Chrome\Application\chrome.exe
REVIEW_BROWSER_EXECUTABLE_PATH=""
# Point this to either the browser user-data root or a concrete profile subdirectory.
# If the path ends with "Default" / "Profile N", Sentify will auto-split it into root + profile.
# Example root: C:\Users\<user>\AppData\Local\Google\Chrome\User Data
# Example profile path: C:\Users\<user>\AppData\Local\Google\Chrome\User Data\Default
REVIEW_BROWSER_USER_DATA_DIR=""
# Optional when REVIEW_BROWSER_USER_DATA_DIR already points at the user-data root.
# Example: Default or Profile 1
REVIEW_BROWSER_PROFILE_DIRECTORY=""
API_RATE_LIMIT_WINDOW_MS=900000
API_RATE_LIMIT_MAX=500
AUTH_RATE_LIMIT_WINDOW_MS=60000
AUTH_RATE_LIMIT_MAX=5
REGISTER_RATE_LIMIT_WINDOW_MS=900000
REGISTER_RATE_LIMIT_MAX=10
IMPORT_RATE_LIMIT_WINDOW_MS=900000
IMPORT_RATE_LIMIT_MAX=10
IMPORT_RUN_HEARTBEAT_MS=15000
IMPORT_RUN_STALE_MS=90000
LOGIN_LOCK_THRESHOLD=5
LOGIN_LOCK_MINUTES=15
PORT=3000
